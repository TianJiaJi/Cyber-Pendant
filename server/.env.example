# ============================================
# Cyber-Pendant 环境配置
# ============================================
# 注意：生产环境请修改以下安全配置

# 服务器端口
PORT=8787

# 数据库路径
DATABASE_PATH=../data/cyber-pendant.sqlite

# 前端基础URL（用于生成吊牌详情页链接）
FRONTEND_BASE_URL=http://localhost:5173

# 管理后台路径
ADMIN_BASE_PATH=/admin
ADMIN_STATIC_DIR=admin/dist

# ============================================
# 安全配置
# ============================================

# CORS允许的来源（逗号分隔，*表示允许所有）
# 生产环境应设置具体的域名，如：https://example.com,https://www.example.com
CORS_ORIGIN=http://localhost:5173

# Token密钥（必须设置，至少32字符）
# 生成方式：openssl rand -base64 32
# 注意：修改此值会使所有现有Token失效，用户需重新登录
TOKEN_SECRET=replace-with-a-long-random-local-secret

# 用户Token密钥（应与TOKEN_SECRET不同）
# 生成方式：openssl rand -base64 32
USER_TOKEN_SECRET=replace-with-a-different-long-random-local-secret

# Token有效期（天）
# 默认30天，可根据需要调整
USER_TOKEN_TTL_DAYS=30

# ============================================
# 管理员配置
# ============================================

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员密码（生产环境请使用强密码）
# 建议使用：openssl rand -base64 16
ADMIN_PASSWORD=replace-with-a-local-admin-password

# ============================================
# 微信小程序配置
# ============================================

# 微信小程序AppID
WECHAT_APP_ID=wx47828dd8e3beb725

# 微信小程序AppSecret
WECHAT_APP_SECRET=replace-with-wechat-app-secret

# 二维码跳转页面
WECHAT_QR_PAGE=pages/garment/detail

# 二维码环境版本（release/trial）
WECHAT_QR_ENV_VERSION=release

# 是否检查路径存在
WECHAT_QR_CHECK_PATH=false

# 二维码宽度
WECHAT_QR_WIDTH=430
